COMPOSE_PROJECT_NAME=amusementpark-local-prod
PUBLIC_BASE_URL=http://amusement.localhost:18080
NPM_HTTP_PORT=18080
NPM_ADMIN_PORT=18181
NPM_HTTPS_PORT=18443
SSR_DIRECT_PORT=14000
SSR_ALLOWED_HOSTS=localhost;127.0.0.1;amusement.localhost
SSR_FORCE_HTTPS=false
MONGO_PORT=27018
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MATOMO_HTTP_PORT=18082
PUBLIC_EDGE_SUBNET=172.31.30.0/24
BACKEND_PRIVATE_SUBNET=172.31.31.0/24
FORWARDED_HEADERS_KNOWN_NETWORKS=172.31.31.0/24
FORWARDED_HEADERS_ALLOWED_HOSTS=amusement.localhost;localhost;127.0.0.1
ALLOWED_HOSTS=amusement.localhost;localhost;127.0.0.1;api;front
MONGO_DATABASE_NAME=AmusementPark
MONGO_INITDB_ROOT_USERNAME=CHANGE_ME
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_APP_USERNAME=CHANGE_ME
MONGO_APP_PASSWORD=CHANGE_ME
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=amusement-park-images
JWT_KEY=CHANGE_ME_AT_LEAST_64_CHARACTERS_RANDOM_SECRET
JWT_ISSUER=AmusementPark.Local
JWT_AUDIENCE=AmusementPark.Local
ADMIN_USER_ENABLED=true
ADMIN_USER_EMAIL=admin@amusement.localhost
ADMIN_USER_PASSWORD=CHANGE_ME
MATOMO_DATABASE=matomo
MATOMO_DATABASE_USERNAME=CHANGE_ME
MATOMO_DATABASE_PASSWORD=CHANGE_ME
MATOMO_DATABASE_ROOT_PASSWORD=CHANGE_ME
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://amusement.localhost:18080/api/auth/external/google/callback

# Cache front SSR des documents SEO publics (/sitemap.xml, /sitemaps/*, /robots.txt).
SSR_SEO_DOCUMENT_CACHE_SECONDS=3600
SSR_SEO_DOCUMENT_CACHE_MAX_ENTRIES=128
