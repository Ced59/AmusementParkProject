COMPOSE_PROJECT_NAME=amusementpark
API_IMAGE=ghcr.io/OWNER/amusementpark-api:CHANGE_ME
FRONT_IMAGE=ghcr.io/OWNER/amusementpark-front:CHANGE_ME
PUBLIC_HTTP_PORT=18080
NPM_DOCKER_NETWORK_NAME=nginx-proxy-network
PUBLIC_DOMAIN=amusement-parks.fun
PUBLIC_BASE_URL=https://amusement-parks.fun
PUBLIC_WWW_BASE_URL=https://www.amusement-parks.fun
BACKEND_PRIVATE_SUBNET=172.30.31.0/24
ALLOWED_HOSTS=amusement-parks.fun;www.amusement-parks.fun;localhost;127.0.0.1;api;amusementpark-api
FORWARDED_HEADERS_ALLOWED_HOSTS=amusement-parks.fun;www.amusement-parks.fun;localhost;127.0.0.1
FORWARDED_HEADERS_KNOWN_NETWORKS=172.30.31.0/24
FORWARDED_HEADERS_FORWARD_LIMIT=2
FRONT_SSR_API_INTERNAL_URL=http://api:8080
SSR_ALLOWED_HOSTS=amusement-parks.fun;www.amusement-parks.fun;localhost;127.0.0.1
SSR_FORCE_HTTPS=true
SSR_CSP_ALLOW_LOCAL_DEV_SOURCES=false
CSP_ENABLED=true
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/security/csp-report
FRONT_CSP_REPORT_URI=/api/security/csp-report
SEO_DEFAULT_LANGUAGE=en
AUTH_RATE_LIMIT_LOGIN_LIMIT=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_EXTERNAL_LOGIN_LIMIT=10
AUTH_RATE_LIMIT_EXTERNAL_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_TOKEN_LIMIT=30
AUTH_RATE_LIMIT_REFRESH_TOKEN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTRATION_LIMIT=5
AUTH_RATE_LIMIT_REGISTRATION_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_EMAIL_CHALLENGE_LIMIT=3
AUTH_RATE_LIMIT_EMAIL_CHALLENGE_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_PASSWORD_RESET_LIMIT=5
AUTH_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=900
ASPNETCORE_ENVIRONMENT=Production

# Journalisation ciblée des requêtes API lentes.
API_PERF_LOGGING_ENABLED=true
API_PERF_LOGGING_LOG_ALL_REQUESTS=false
API_PERF_LOGGING_SLOW_REQUEST_THRESHOLD_MS=750
API_PERF_LOGGING_ALWAYS_LOG_STATUS_CODE_AT_LEAST=500

MONGO_DATABASE_NAME=AmusementPark
MONGO_INITDB_ROOT_USERNAME=CHANGE_ME
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_APP_USERNAME=CHANGE_ME
MONGO_APP_PASSWORD=CHANGE_ME
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-07-23T15-54-02Z
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=amusement-park-images
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
JWT_KEY=CHANGE_ME_AT_LEAST_64_CHARACTERS_RANDOM_SECRET
JWT_ISSUER=AmusementPark
JWT_AUDIENCE=AmusementPark
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://amusement-parks.fun/api/auth/external/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
EMAIL_MODE=Console
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_SSL=false
EMAIL_USE_STARTTLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@amusement-parks.fun
EMAIL_FROM_NAME=Amusement Park
ADMIN_USER_ENABLED=false
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=

# Cache front SSR des documents SEO publics (/sitemap.xml, /sitemaps/*, /robots.txt).
SSR_SEO_DOCUMENT_CACHE_SECONDS=3600
SSR_SEO_DOCUMENT_CACHE_MAX_ENTRIES=128

# SSR public réactivé, mais rendu dynamique strictement borné.
SSR_RENDER_ENABLED=true
SSR_PAGE_CACHE_SECONDS=86400
SSR_PAGE_CACHE_MAX_ENTRIES=2000
SSR_RENDER_MAX_CONCURRENCY=1
SSR_RENDER_QUEUE_MAX_ENTRIES=100
SSR_RENDER_QUEUE_WARNING_THRESHOLD=75
SSR_SLOW_RENDER_THRESHOLD_MILLISECONDS=3000

# Cache HTML SSR disque dans /tmp du conteneur front.
# Les cookies Matomo/analytics ne doivent pas invalider le cache public.
SSR_PUBLIC_PAGE_CACHE_ALLOW_AUTH_COOKIES=true
SSR_DISK_PAGE_CACHE_ENABLED=true
SSR_DISK_PAGE_CACHE_DIR=/tmp/amusementpark-ssr-page-cache
SSR_DISK_PAGE_CACHE_MAX_BYTES=268435456
