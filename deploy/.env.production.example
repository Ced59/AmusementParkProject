# Copy to .env on the VPS or let GitHub Actions generate .env from secrets/variables.
# Never commit the real .env file.

COMPOSE_PROJECT_NAME=amusementpark
API_IMAGE=ghcr.io/YOUR_ORG/amusementpark-api:YOUR_SHA
FRONT_IMAGE=ghcr.io/YOUR_ORG/amusementpark-front:YOUR_SHA

ASPNETCORE_ENVIRONMENT=Production
PUBLIC_HTTP_PORT=8080
PUBLIC_DOMAIN=amusement-parks.fun
PUBLIC_BASE_URL=https://amusement-parks.fun
PUBLIC_WWW_BASE_URL=https://www.amusement-parks.fun
SEO_DEFAULT_LANGUAGE=en
SEO_MAX_DYNAMIC_URLS_PER_TYPE=10000

# M18.2 / M18.3 host and proxy hardening.
ALLOWED_HOSTS=amusement-parks.fun;www.amusement-parks.fun;localhost;127.0.0.1;amusementpark-api
PUBLIC_EDGE_SUBNET=172.30.30.0/24
BACKEND_PRIVATE_SUBNET=172.30.31.0/24
FORWARDED_HEADERS_ALLOWED_HOSTS=amusement-parks.fun;www.amusement-parks.fun;localhost;127.0.0.1
FORWARDED_HEADERS_KNOWN_NETWORKS=172.30.31.0/24
FORWARDED_HEADERS_FORWARD_LIMIT=2

# M18.4 / M18.5 CSP. Keep Report-Only until staging/production reports are clean.
CSP_ENABLED=true
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/security/csp-report

# M18.6 authentication rate limits.
AUTH_RATE_LIMIT_LOGIN_LIMIT=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_EXTERNAL_LOGIN_LIMIT=10
AUTH_RATE_LIMIT_EXTERNAL_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_TOKEN_LIMIT=30
AUTH_RATE_LIMIT_REFRESH_TOKEN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTRATION_LIMIT=5
AUTH_RATE_LIMIT_REGISTRATION_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_EMAIL_CHALLENGE_LIMIT=3
AUTH_RATE_LIMIT_EMAIL_CHALLENGE_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_PASSWORD_RESET_LIMIT=5
AUTH_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=900

# MongoDB. Replace all values before any production deployment.
MONGO_DATABASE_NAME=AmusementPark
MONGO_INITDB_ROOT_USERNAME=CHANGE_ME
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_APP_USERNAME=CHANGE_ME
MONGO_APP_PASSWORD=CHANGE_ME

# MinIO. Replace all values before any production deployment.
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-07-23T15-54-02Z
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=amusement-park-images
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# JWT. Use a long random secret. At least 32 chars; 64+ recommended.
JWT_KEY=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=https://amusement-parks.fun
JWT_AUDIENCE=https://amusement-parks.fun

# Google OAuth is part of the public auth flow and must be configured for production.
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://amusement-parks.fun/auth/google/callback

# Facebook is optional for now. Leave empty only if intentionally disabled.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email. Console can be used for a private smoke test; Smtp is expected before real users.
EMAIL_MODE=Console
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_SSL=false
EMAIL_USE_STARTTLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@amusement-parks.fun
EMAIL_FROM_NAME=Amusement Park

# Optional startup admin creation. Prefer false after the first controlled bootstrap.
ADMIN_USER_ENABLED=false
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=
