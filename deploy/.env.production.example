COMPOSE_PROJECT_NAME=amusementpark
API_IMAGE=ghcr.io/<github-owner-lowercase>/amusementpark-api:<commit-sha>
FRONT_IMAGE=ghcr.io/<github-owner-lowercase>/amusementpark-front:<commit-sha>

PUBLIC_DOMAIN=amusement-parks.fun
PUBLIC_BASE_URL=https://amusement-parks.fun
PUBLIC_HTTP_PORT=8080

ASPNETCORE_ENVIRONMENT=Production

MONGO_DATABASE_NAME=AmusementPark
MONGO_INITDB_ROOT_USERNAME=amusementpark_root
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_SECRET
MONGO_APP_USERNAME=amusementpark_app
MONGO_APP_PASSWORD=CHANGE_ME_LONG_RANDOM_SECRET

MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-07-23T15-54-02Z
MINIO_ROOT_USER=CHANGE_ME_MINIO_ADMIN
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_SECRET
MINIO_BUCKET=amusement-park-images
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_KEY=CHANGE_ME_AT_LEAST_64_RANDOM_CHARS
JWT_ISSUER=amusement-parks.fun
JWT_AUDIENCE=amusement-parks.fun

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://amusement-parks.fun/auth/google-response
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

EMAIL_MODE=Console
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_SSL=false
EMAIL_USE_STARTTLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@amusement-parks.fun
EMAIL_FROM_NAME=Amusement Park

ADMIN_USER_ENABLED=false
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=
