{
  "name": "amusement-park",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate-version": "node scripts/generate-version.mjs",
    "release:version": "node scripts/set-release-version.mjs",
    "release:version:print": "node scripts/read-release-version.mjs",
    "security:patch-geolocation-policy": "node tools/patch-geolocation-permissions-policy.mjs",
    "prestart": "npm run generate-version && npm run i18n:build",
    "start": "ng serve",
    "prebuild": "npm run generate-version && npm run i18n:build && npm run security:patch-geolocation-policy",
    "build": "ng build",
    "prewatch": "npm run generate-version && npm run i18n:build",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run generate-version && npm run i18n:build",
    "test": "ng test",
    "serve:ssr:AmusementPark": "node dist/amusement-park/server/server.mjs",
    "pretest:ci": "npm run generate-version && npm run i18n:build",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "prebuild:ssr:local": "npm run generate-version && npm run i18n:build && npm run security:patch-geolocation-policy",
    "build:ssr:local": "ng build --configuration local-production",
    "seo:ssr-smoke": "node tools/seo-ssr-smoke.mjs",
    "architecture:facade-ports": "node tools/architecture/check-facade-data-ports.mjs",
    "i18n:build": "node tools/i18n-build.mjs",
    "i18n:check": "node tools/i18n-build.mjs --check && node tools/i18n-check.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.18",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-browser-dynamic": "21.2.18",
    "@angular/platform-server": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/ssr": "21.2.19",
    "@lucide/angular": "^1.23.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "express": "^4.18.2",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "ngx-matomo-client": "^9.1.0",
    "qrcode": "^1.5.4",
    "quill": "2.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^18.18.0",
    "@types/qrcode": "^1.5.6",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "5.9.3"
  }
}
