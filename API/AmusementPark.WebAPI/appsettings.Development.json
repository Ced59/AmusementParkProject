{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Initialization": {
    "AdminUser": {
      "Enabled": true,
      "Email": "admin@amusement-park.local",
      "Password": "",
      "FirstName": "Admin",
      "LastName": "User",
      "PreferredLanguage": "FR"
    }
  },
  "AllowedHosts": "*",
  "ForwardedHeaders": {
    "ForwardLimit": 2,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "KnownNetworks": [
      "127.0.0.0/8"
    ],
    "AllowedHosts": [
      "localhost",
      "127.0.0.1"
    ]
  },
  "Security": {
    "ContentSecurityPolicy": {
      "Enabled": true,
      "ReportOnly": true,
      "ReportUri": "/security/csp-report"
    }
  },
  "RateLimiting": {
    "Authentication": {
      "Login": {
        "PermitLimit": 20,
        "WindowSeconds": 60
      },
      "ExternalLogin": {
        "PermitLimit": 20,
        "WindowSeconds": 60
      },
      "RefreshToken": {
        "PermitLimit": 60,
        "WindowSeconds": 60
      },
      "Registration": {
        "PermitLimit": 10,
        "WindowSeconds": 900
      },
      "EmailChallenge": {
        "PermitLimit": 10,
        "WindowSeconds": 900
      },
      "PasswordReset": {
        "PermitLimit": 10,
        "WindowSeconds": 900
      }
    }
  },
  "Seo": {
    "PublicBaseUrl": "http://localhost:4200",
    "DefaultLanguage": "en",
    "SupportedLanguages": [
      "en",
      "fr",
      "es",
      "de",
      "it",
      "pl",
      "nl",
      "pt"
    ],
    "MaxDynamicUrlsPerType": 5000,
    "RobotsDisallowPaths": [
      "/api/",
      "/{lang}/admin/",
      "/{lang}/profile",
      "/{lang}/confirm-account",
      "/{lang}/forgot-password",
      "/{lang}/reset-password"
    ]
  },
  "Authentication": {
    "Local": {
      "FrontendBaseUrl": "http://localhost:4200"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "AllowCredentials": true,
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "PATCH",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "Accept-Language",
      "X-Requested-With"
    ],
    "ExposedHeaders": [
      "Retry-After",
      "X-Rate-Limit-Limit",
      "X-Rate-Limit-Remaining",
      "X-Rate-Limit-Reset"
    ]
  }
}
